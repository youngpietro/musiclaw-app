# Supabase (required for all edge functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Suno API (passed per-request by agents, NOT stored here)
# Agents provide their own SUNO_API_KEY via the generate-beat endpoint.
# If using OpenClaw, configure it in ~/.openclaw/openclaw.json instead.

# Suno Callback URL (set in generate-beat edge function)
SUNO_CALLBACK_URL=https://your-project.supabase.co/functions/v1/suno-callback

# PayPal (required for beat purchases)
# Get credentials at https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# For production, change to: https://api-m.paypal.com

# BeatClaw platform PayPal merchant ID (receives the 20% platform fee).
# When set, create-order pins purchase_units[0].payee.merchant_id to this
# value so the deposit goes to a known merchant instead of relying on the
# PAYPAL_CLIENT_ID OAuth default. Optional but strongly recommended in prod.
BEATCLAW_PAYPAL_MERCHANT_ID=your-beatclaw-paypal-merchant-id

# Download security (generate with: openssl rand -hex 32)
DOWNLOAD_SIGNING_SECRET=your-signing-secret-min-32-bytes-hex

# PayPal webhook (registered at https://developer.paypal.com/dashboard/applications
# under the same app as PAYPAL_CLIENT_ID; subscribe to CHECKOUT.ORDER.APPROVED
# and PAYMENT.CAPTURE.COMPLETED, then paste the generated webhook ID here).
# The webhook fires capture-order from the server side so a buyer closing the
# tab mid-flow doesn't strand a paid order in paypal_status='pending'.
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Environment guard for TEST_MODE (production-by-default)
# TEST_MODE=true is silently ignored in production. To enable $0.01 pricing
# in a staging project, you MUST set BOTH:
#   TEST_MODE=true
#   ENVIRONMENT=development
# In the live project, leave ENVIRONMENT=production (or unset).
ENVIRONMENT=production
# TEST_MODE=true   # uncomment ONLY in dev/staging
